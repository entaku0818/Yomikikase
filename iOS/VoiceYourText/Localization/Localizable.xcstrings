    "%@機能は現在開発中です。今後のアップデートをお楽しみに！": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die %@-Funktion ist derzeit in Entwicklung. Freuen Sie sich auf Updates!"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The %@ feature is currently under development. Stay tuned for updates!"
