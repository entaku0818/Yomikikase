    "「%@」を完全に削除します。この操作は取り消せません。": {
      "comment": "A confirmation message for permanently deleting a file. The argument is the title of the file to be deleted.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" wird dauerhaft gelöscht. Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Permanently delete \"%@\". This action cannot be undone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminar permanentemente \"%@\". Esta acción no se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprimer définitivement \"%@\". Cette action est irréversible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina definitivamente \"%@\". Questa azione non può essere annullata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」を完全に削除します。この操作は取り消せません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\"을(를) 완전히 삭제합니다. 이 작업은 취소할 수 없습니다."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ลบ \"%@\" อย่างถาวร การดำเนินการนี้ไม่สามารถยกเลิกได้"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" kalıcı olarak silinecek. Bu işlem geri alınamaz."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Xóa vĩnh viễn \"%@\". Hành động này không thể hoàn tác."
          }
        }
      }
    },
